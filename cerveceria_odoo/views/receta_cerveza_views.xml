<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════
         RECETA CERVEZA - FORM VIEW
    ══════════════════════════════════════════════════════════════ -->
    <record id="view_receta_cerveza_form" model="ir.ui.view">
        <field name="name">cerveceria.receta.form</field>
        <field name="model">cerveceria.receta</field>
        <field name="arch" type="xml">
            <form string="Receta de Cerveza">
                <header>
                    <button name="action_activar" string="Activar" type="object"
                            class="btn-primary"
                            invisible="estado != 'borrador'"/>
                    <button name="action_archivar" string="Archivar" type="object"
                            invisible="estado != 'activa'"/>
                    <button name="action_borrador" string="Volver a Borrador" type="object"
                            invisible="estado != 'archivada'"/>
                    <field name="estado" widget="statusbar"
                           statusbar_visible="borrador,activa,archivada"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_ver_lotes" type="object"
                                class="oe_stat_button" icon="fa-flask">
                            <field name="lotes_count" widget="statinfo" string="Lotes"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Nombre de la Receta"/>
                        <h1>
                            <field name="name" placeholder="Ej: Pale Ale Verano"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Información General">
                            <field name="codigo" readonly="1"/>
                            <field name="estilo_cerveza"/>
                            <field name="volumen_produccion"/>
                        </group>
                        <group string="Parámetros Técnicos">
                            <field name="densidad_original"/>
                            <field name="densidad_final"/>
                            <field name="abv" readonly="1"/>
                            <field name="ibu"/>
                            <field name="srm"/>
                        </group>
                    </group>
                    <group string="Tiempos de Proceso">
                        <group>
                            <field name="tiempo_macerado"/>
                            <field name="tiempo_coccion"/>
                        </group>
                        <group>
                            <field name="tiempo_fermentacion"/>
                            <field name="tiempo_madurado"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Ingredientes" name="ingredientes">
                            <field name="ingrediente_ids" widget="one2many_list">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="tipo_ingrediente"/>
                                    <field name="product_id"/>
                                    <field name="cantidad"/>
                                    <field name="uom_id"/>
                                    <field name="momento_adicion"/>
                                    <field name="notas"/>
                                </list>
                            </field>
                        </page>
                        <page string="Descripción" name="descripcion">
                            <field name="descripcion" placeholder="Descripción de la receta, historia, maridaje, etc."/>
                        </page>
                        <page string="Herencias" name="herencias">
                            <group string="Inventario (Herencia)">
                                <field name="route_ids" widget="many2many_tags"/>
                            </group>
                            <group string="Fabricación (Herencia)">
                                <field name="mrp_bom_id"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         RECETA CERVEZA - LIST VIEW
    ══════════════════════════════════════════════════════════════ -->
    <record id="view_receta_cerveza_list" model="ir.ui.view">
        <field name="name">cerveceria.receta.list</field>
        <field name="model">cerveceria.receta</field>
        <field name="arch" type="xml">
            <list string="Recetas de Cerveza"
                  decoration-muted="estado == 'archivada'"
                  decoration-info="estado == 'borrador'">
                <field name="codigo"/>
                <field name="name"/>
                <field name="estilo_cerveza"/>
                <field name="volumen_produccion"/>
                <field name="densidad_original"/>
                <field name="densidad_final"/>
                <field name="abv"/>
                <field name="ibu"/>
                <field name="lotes_count"/>
                <field name="estado" widget="badge"
                       decoration-success="estado == 'activa'"
                       decoration-warning="estado == 'borrador'"
                       decoration-muted="estado == 'archivada'"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         RECETA CERVEZA - SEARCH VIEW
    ══════════════════════════════════════════════════════════════ -->
    <record id="view_receta_cerveza_search" model="ir.ui.view">
        <field name="name">cerveceria.receta.search</field>
        <field name="model">cerveceria.receta</field>
        <field name="arch" type="xml">
            <search string="Buscar Recetas">
                <field name="name" string="Nombre"/>
                <field name="codigo" string="Código"/>
                <field name="estilo_cerveza" string="Estilo"/>
                <filter string="Activas" name="activas" domain="[('estado','=','activa')]"/>
                <filter string="Borradores" name="borradores" domain="[('estado','=','borrador')]"/>
                <filter string="Archivadas" name="archivadas" domain="[('estado','=','archivada')]"/>
                <separator/>
                <filter string="Lager" name="lager" domain="[('estilo_cerveza','=','lager')]"/>
                <filter string="Ale" name="ale" domain="[('estilo_cerveza','=','ale')]"/>
                <filter string="IPA" name="ipa" domain="[('estilo_cerveza','=','ipa')]"/>
                <filter string="Stout" name="stout" domain="[('estilo_cerveza','=','stout')]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Estilo" name="by_estilo" context="{'group_by':'estilo_cerveza'}"/>
                    <filter string="Estado" name="by_estado" context="{'group_by':'estado'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         RECETA CERVEZA - KANBAN VIEW
    ══════════════════════════════════════════════════════════════ -->
    <record id="view_receta_cerveza_kanban" model="ir.ui.view">
        <field name="name">cerveceria.receta.kanban</field>
        <field name="model">cerveceria.receta</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="estilo_cerveza">
                <field name="name"/>
                <field name="estilo_cerveza"/>
                <field name="abv"/>
                <field name="ibu"/>
                <field name="lotes_count"/>
                <field name="estado"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <field name="estado" widget="label_selection"
                                       options="{'classes': {'activa': 'success', 'borrador': 'warning', 'archivada': 'muted'}}"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <span>ABV: <field name="abv"/>%</span>
                                <span class="ms-2">IBU: <field name="ibu"/></span>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <span class="badge bg-info"><field name="lotes_count"/> lotes</span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         ACTION
    ══════════════════════════════════════════════════════════════ -->
    <record id="action_receta_cerveza" model="ir.actions.act_window">
        <field name="name">Recetas de Cerveza</field>
        <field name="res_model">cerveceria.receta</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_receta_cerveza_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                ¡Crea tu primera receta de cerveza!
            </p>
        </field>
    </record>

</odoo>
