<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════
         LOTE PRODUCCION - FORM VIEW
    ══════════════════════════════════════════════════════════════ -->
    <record id="view_lote_produccion_form" model="ir.ui.view">
        <field name="name">cerveceria.lote.form</field>
        <field name="model">cerveceria.lote</field>
        <field name="arch" type="xml">
            <form string="Lote de Producción">
                <header>
                    <button name="action_iniciar" string="Iniciar Producción" type="object"
                            class="btn-primary"
                            invisible="estado != 'planificado'"/>
                    <button name="action_fermentar" string="Pasar a Fermentación" type="object"
                            class="btn-primary"
                            invisible="estado != 'en_proceso'"/>
                    <button name="action_madurar" string="Pasar a Madurado" type="object"
                            invisible="estado != 'fermentando'"/>
                    <button name="action_envasar" string="Envasar" type="object"
                            invisible="estado != 'madurando'"/>
                    <button name="action_liberar" string="Liberar Lote" type="object"
                            class="btn-success"
                            invisible="estado != 'envasado'"/>
                    <button name="action_cancelar" string="Cancelar" type="object"
                            class="btn-danger"
                            invisible="estado in ('liberado','cancelado')"/>
                    <field name="estado" widget="statusbar"
                           statusbar_visible="planificado,en_proceso,fermentando,madurando,envasado,liberado"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_ver_insumos" type="object"
                                class="oe_stat_button" icon="fa-cubes">
                            <field name="insumos_count" widget="statinfo" string="Insumos"/>
                        </button>
                        <button name="action_ver_controles" type="object"
                                class="oe_stat_button" icon="fa-thermometer-half">
                            <field name="controles_count" widget="statinfo" string="Controles"/>
                        </button>
                        <button name="action_ver_ventas" type="object"
                                class="oe_stat_button" icon="fa-shopping-cart"
                                invisible="ventas_count == 0">
                            <field name="ventas_count" widget="statinfo" string="Ventas"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                        <field name="descripcion" placeholder="Alias del lote (ej: 'Batch Verano 2025')"/>
                    </div>
                    <group>
                        <group string="Receta y Responsable">
                            <field name="receta_id"/>
                            <field name="estilo_cerveza" readonly="1"/>
                            <field name="responsable_id"/>
                        </group>
                        <group string="Volúmenes">
                            <field name="volumen_planificado"/>
                            <field name="volumen_real"/>
                            <field name="rendimiento" widget="progressbar"/>
                        </group>
                    </group>
                    <group>
                        <group string="Fechas">
                            <field name="fecha_inicio"/>
                            <field name="fecha_fin_estimada"/>
                            <field name="fecha_fin_real"/>
                            <field name="fecha_envasado"/>
                        </group>
                        <group string="Parámetros Reales">
                            <field name="densidad_original_real"/>
                            <field name="densidad_final_real"/>
                            <field name="abv_real" readonly="1"/>
                            <field name="ibu_real"/>
                            <field name="temperatura_fermentacion"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notas de Producción" name="notas">
                            <field name="notas_produccion" placeholder="Anota eventos, decisiones e incidencias del proceso de producción..."/>
                        </page>
                        <page string="Herencias" name="herencias">
                            <group string="Fabricación (Herencia)">
                                <field name="mrp_production_id"/>
                            </group>
                            <group string="Inventario (Herencia)">
                                <field name="stock_lot_id"/>
                            </group>
                            <group string="Ventas (Herencia)">
                                <field name="sale_order_ids" widget="many2many_tags"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         LOTE PRODUCCION - LIST VIEW
    ══════════════════════════════════════════════════════════════ -->
    <record id="view_lote_produccion_list" model="ir.ui.view">
        <field name="name">cerveceria.lote.list</field>
        <field name="model">cerveceria.lote</field>
        <field name="arch" type="xml">
            <list string="Lotes de Producción"
                  decoration-success="estado == 'liberado'"
                  decoration-warning="estado in ('fermentando','madurando')"
                  decoration-info="estado == 'planificado'"
                  decoration-danger="estado == 'cancelado'">
                <field name="name"/>
                <field name="receta_id"/>
                <field name="estilo_cerveza"/>
                <field name="responsable_id"/>
                <field name="fecha_inicio"/>
                <field name="fecha_fin_estimada"/>
                <field name="volumen_planificado"/>
                <field name="volumen_real"/>
                <field name="rendimiento" widget="progressbar"/>
                <field name="insumos_count"/>
                <field name="controles_count"/>
                <field name="estado" widget="badge"
                       decoration-success="estado == 'liberado'"
                       decoration-warning="estado in ('fermentando','madurando','envasado')"
                       decoration-info="estado == 'planificado'"
                       decoration-primary="estado == 'en_proceso'"
                       decoration-danger="estado == 'cancelado'"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         LOTE PRODUCCION - SEARCH VIEW
    ══════════════════════════════════════════════════════════════ -->
    <record id="view_lote_produccion_search" model="ir.ui.view">
        <field name="name">cerveceria.lote.search</field>
        <field name="model">cerveceria.lote</field>
        <field name="arch" type="xml">
            <search string="Buscar Lotes">
                <field name="name" string="Nº Lote"/>
                <field name="receta_id" string="Receta"/>
                <field name="responsable_id" string="Maestro Cervecero"/>
                <filter string="Planificados" name="planificados" domain="[('estado','=','planificado')]"/>
                <filter string="En Proceso" name="en_proceso" domain="[('estado','=','en_proceso')]"/>
                <filter string="Fermentando" name="fermentando" domain="[('estado','=','fermentando')]"/>
                <filter string="Madurando" name="madurando" domain="[('estado','=','madurando')]"/>
                <filter string="Envasados" name="envasados" domain="[('estado','=','envasado')]"/>
                <filter string="Liberados" name="liberados" domain="[('estado','=','liberado')]"/>
                <separator/>
                <filter string="Este mes" name="este_mes"
                        domain="[('fecha_inicio','&gt;=', (context_today().replace(day=1)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Estado" name="by_estado" context="{'group_by':'estado'}"/>
                    <filter string="Receta" name="by_receta" context="{'group_by':'receta_id'}"/>
                    <filter string="Maestro Cervecero" name="by_responsable" context="{'group_by':'responsable_id'}"/>
                    <filter string="Estilo" name="by_estilo" context="{'group_by':'estilo_cerveza'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_lote_produccion" model="ir.actions.act_window">
        <field name="name">Lotes de Producción</field>
        <field name="res_model">cerveceria.lote</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_lote_produccion_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                ¡Registra tu primer lote de producción!
            </p>
        </field>
    </record>

</odoo>
